# Copy this file to `.env` and fill in the values you have.
# Everything here is FREE to obtain. Sources with missing credentials are
# skipped automatically (the app logs a warning and keeps going).

# ---------------------------------------------------------------------------
# Dashboard access (IMPORTANT when running on a server you reach from your phone)
#   Leave DASHBOARD_PASSWORD blank for localhost-only dev (no auth).
#   Set it to password-protect the dashboard over the network. The deploy
#   script (deploy/setup.sh) generates a strong one automatically.
# ---------------------------------------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
# DASHBOARD_HOST=0.0.0.0     # set by the service on a server; leave unset locally

# ---------------------------------------------------------------------------
# Reddit  — TODO: create a free "script" app at https://www.reddit.com/prefs/apps
# ---------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trend-engine/0.1 by u/your_reddit_username

# ---------------------------------------------------------------------------
# YouTube Data API v3 — TODO: create a free API key in Google Cloud Console
#   https://console.cloud.google.com/  ->  APIs & Services -> Credentials
#   Enable "YouTube Data API v3" (free tier: 10,000 units/day)
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=

# ---------------------------------------------------------------------------
# YouTube UPLOAD (autopilot posting of Shorts) — TODO
#   Uploading needs OAuth (an API key alone is read-only). In Google Cloud
#   Console create an "OAuth client ID" of type "Desktop app", download the
#   JSON, and point this at it. Then run:  python run.py youtube-auth
#   (that opens a browser once and caches a refresh token under ~/.config).
# ---------------------------------------------------------------------------
YOUTUBE_OAUTH_CLIENT_SECRET=./client_secret.json

# ---------------------------------------------------------------------------
# Groq — OPTIONAL, FREE hosted LLM. Only needed if you set llm.provider: groq
# (great for a small/cheap server with no room for a local model).
# TODO: free key from https://console.groq.com/keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic (Claude) — OPTIONAL. Only needed if you switch llm.provider to
# "anthropic" in config.yaml. TODO: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Publishing adapters — OPTIONAL, for when you wire up the official free APIs.
# These are only read by the (stubbed) publishers in trendengine/publishers/.
# ---------------------------------------------------------------------------
# Meta Graph API (Instagram Business / Facebook Page)
META_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
# TikTok Content Posting API
TIKTOK_ACCESS_TOKEN=
